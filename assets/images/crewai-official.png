website-files.com/69a111972d2e0bbcc6adb934/js/webflow.schunk.36b8fb49256177c8.js" type="text/javascript" integrity="sha384-4abIlA5/v7XaW1HMXKBgnUuhnjBYJ/Z9C1OSg4OhmVw9O3QeHJ/qJqFBERCDPv7G" crossorigin="anonymous"></script><script src="https://cdn.prod.website-files.com/69a111972d2e0bbcc6adb934/js/webflow.schunk.b48674dbcc3b13e4.js" type="text/javascript" integrity="sha384-wdUBwXJGS7ABoA7ePcsCoPvv//kt5mdbp7dUxlpTGI4NbTgml3WvKhzKKOx69gur" crossorigin="anonymous"></script><script src="https://cdn.prod.website-files.com/69a111972d2e0bbcc6adb934/js/webflow.2c90d3d0.afaff11831b08df6.js" type="text/javascript" integrity="sha384-vOkQd+2DYRxoj4C79w3WkfjBI4nUxX26ycTVSPcxjX5R6gE9XU6Yx5RfcJPtlu5W" crossorigin="anonymous"></script><!-- Request a demo form integration with HubSpot -->
<script>
document.addEventListener("DOMContentLoaded", function () {
  const form = document.getElementById("request-a-demo-form");
  if (!form) return;

  form.setAttribute("data-hs-ignore", "true");
  form.classList.add("hs-form-ignored");

  const portalId = "45732688";
  const formId   = "3a8a3651-588a-436d-943b-376bee2efb8b";

  form.addEventListener("submit", async function (e) {
    e.preventDefault();

    const data = new FormData(form);
    const btn = form.querySelector('[type="submit"]');
    const originalText = btn?.textContent || "Submit";
    
    if (btn) {
      btn.disabled = true;
      btn.textContent = "Submitting...";
    }

    const hutk = document.cookie
      .split("; ")
      .find(r => r.startsWith("hubspotutk="))
      ?.split("=")[1];

    const payload = {
      fields: [
        { objectTypeId: "0-1", name: "email",     value: data.get("email")     || "" },
        { objectTypeId: "0-1", name: "firstname", value: data.get("firstname") || "" },
        { objectTypeId: "0-1", name: "lastname",  value: data.get("lastname")  || "" },
        { objectTypeId: "0-1", name: "jobtitle",  value: data.get("jobtitle")  || "" },
        { objectTypeId: "0-1", name: "company",   value: data.get("name")      || "" }
      ],
      context: {
        pageUri: window.location.href,
        pageName: document.title,
        ...(hutk && { hutk })
      }
    };

    const endpoint = `https://api.hsforms.com/submissions/v3/integration/submit/${portalId}/${formId}`;

    try {
      const res = await fetch(endpoint, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(payload)
      });
      if (!res.ok) throw new Error(await res.text());

      form.reset();
      form.style.display = "none";
      document.getElementById("request-a-demo-success-message")
        ?.style.setProperty("display","block","important");
    } catch (err) {
      console.error("HubSpot submission error:", err);
      alert("Error submitting the form. Please try again.");
      
      // Restore button on error
      if (btn) {
        btn.textContent = originalText;
        btn.disabled = false;
      }
    } finally {
      // Only disable if successful (handled above for errors)
      if (btn && !btn.disabled) {
        btn.disabled = false;
      }
    }
  });
});
</script>




