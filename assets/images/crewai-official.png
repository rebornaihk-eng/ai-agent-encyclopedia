<!--Footer NEWSLETTER hubspot form connection-->

<script>
document.addEventListener("DOMContentLoaded", function () {
  const form = document.getElementById("newsletter-form");
  if (!form) return;

  const portalId = "45732688";
  const formId   = "5b617f4a-36b2-42ac-863a-edc39b00697a";

  form.addEventListener("submit", async function (e) {
    e.preventDefault();
    const data = new FormData(form);
    const btn  = form.querySelector('[type="submit"]');
    if (btn) btn.disabled = true;

    // get hubspotutk for analytics
    const hutk = document.cookie
      .split("; ")
      .find(r => r.startsWith("hubspotutk="))
      ?.split("=")[1];

    // build HS payload - only email field
    const payload = {
      fields: [
        { objectTypeId: "0-1", name: "email", value: data.get("email") || "" }
      ],
      context: {
        pageUri:  window.location.href,
        pageName: document.title,
        ...(hutk && { hutk })
      }
    };

    const endpoint =
      `https://api.hsforms.com/submissions/v3/integration/submit/` +
      `${portalId}/${formId}`;

    try {
      const res = await fetch(endpoint, {
        method:  "POST",
        headers: { "Content-Type": "application/json" },
        body:    JSON.stringify(payload)
      });
      if (!res.ok) throw new Error(await res.text());

      // success
      form.reset();
      form.style.display = "none";
      document.getElementById("newsletter-success-message")
              ?.style.setProperty("display","block");
    } catch (err) {
      console.error("HubSpot newsletter submission error:", err);
      alert("Error submitting the form. Please try again.");
    } finally {
      if (btn) btn.disabled = false;
    }
  });
});
</script>

<!--END Footer NEWSLETTER hubspot form connection-->


<script>
const lenis = new Lenis({
  duration: 1.2,
  easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
  orientation: 'vertical',
  gestureOrientation: 'vertical',
  smoothWheel: true,
  wheelMultiplier: 1,
  smoothTouch: false,
  touchMultiplier: 2,
  infinite: false,
})

function raf(time) {
  lenis.raf(time)
  requestAnimationFrame(raf)
}

requestAnimationFrame(raf)
</script>


</body></html>